root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml,md,csproj,props}]
indent_size = 2

# Kiota output is machine generated. Do not lint, format, or analyze it.
[src/Generated/**.cs]
generated_code = true
dotnet_analyzer_diagnostic.severity = none
